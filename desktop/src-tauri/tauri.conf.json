{
  "package": {
    "productName": "NogoWallet",
    "version": "1.0.0"
  },
  "build": {
    "distDir": "../../dist",
    "devPath": "http://localhost:5174",
    "beforeDevCommand": "cd .. && npm run dev",
    "beforeBuildCommand": "cd .. && npm run build"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "com.nogochain.wallet",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "category": "Finance",
      "shortDescription": "NogoChain Official Wallet",
      "longDescription": "A secure, cross-platform wallet for NogoChain blockchain",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      },
      "macOS": {
        "minimumSystemVersion": "10.13",
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      }
    },
    "updater": {
      "active": false
    },
    "allowlist": {
      "all": true,
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://*", "https://*"]
      }
    },
    "windows": [
      {
        "title": "NogoWallet - NogoChain Official Wallet",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ]
  }
}
