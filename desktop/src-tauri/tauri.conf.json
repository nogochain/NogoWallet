{
  "package": {
    "productName": "NogoWallet",
    "version": "1.0.0"
  },
  "build": {
    "distDir": "../../dist",
    "devPath": "http://localhost:5174",
    "beforeDevCommand": "cd .. && npm run dev",
    "beforeBuildCommand": "cd .. && npm run build"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "com.nogochain.wallet",
      "icon": ["icons/icon.ico"]
    },
    "updater": {
      "active": false
    },
    "allowlist": {
      "all": true,
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://*", "https://*"]
      }
    },
    "windows": [
      {
        "title": "NogoWallet - NogoChain Official Wallet",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ]
  }
}
