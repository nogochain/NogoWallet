{
  "package": {
    "productName": "NogoWallet",
    "version": "1.0.0"
  },
  "build": {
    "distDir": "../../dist",
    "devPath": "http://localhost:5174",
    "beforeDevCommand": "cd .. && npm run dev",
    "beforeBuildCommand": "cd .. && npm run build",
    "withGlobalTauri": true
  },
  "tauri": {
    "bundle": {
      "active": false,
      "identifier": "com.nogochain.wallet"
    },
    "updater": {
      "active": false
    },
    "allowlist": {
      "all": true,
      "fs": {
        "all": true,
        "scope": ["$APPDATA/**"]
      },
      "dialog": {
        "all": true,
        "ask": true,
        "confirm": true,
        "message": true,
        "open": true,
        "save": true
      },
      "shell": {
        "all": false,
        "open": true
      },
      "clipboard": {
        "all": true,
        "writeText": true,
        "readText": true
      }
    },
    "windows": [
      {
        "title": "NogoWallet - NogoChain Official Wallet",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https://api.qrserver.com; connect-src 'self' http://localhost:* https://*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;"
    }
  }
}
